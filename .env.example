# Open Banking (Yapily) - Credenziali
YAPILY_APPLICATION_UUID=your_application_uuid
YAPILY_APPLICATION_SECRET=your_application_secret
YAPILY_API_BASE=https://api.yapily.com

# Per sviluppo locale puoi inserire un consent token statico
# ottenuto dal flusso di autorizzazione Yapily (NON committare mai .env)
YAPILY_CONSENT_TOKEN=your_consent_token_here

# URL di redirect dopo autenticazione banca (deve essere raggiungibile)
REDIRECT_URL=http://localhost:3000/callback.html

# Porta del server
PORT=3000
