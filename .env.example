# GoCardless Bank Account Data - User Secrets
# Ottienili da: https://bankaccountdata.gocardless.com/user-secrets/
GOCARDLESS_SECRET_ID=your_secret_id
GOCARDLESS_SECRET_KEY=your_secret_key

# URL di redirect dopo autenticazione banca (deve essere raggiungibile)
REDIRECT_URL=http://localhost:3000/callback

# Porta del server
PORT=3000
